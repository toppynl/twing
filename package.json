{
  "name": "twing",
  "description": "First-class Twig engine for Node.js",
  "author": "Eric MORAND <eric.morand@gmail.com>",
  "keywords": [
    "browser",
    "compiler",
    "template",
    "twig",
    "twig-engine",
    "typescript"
  ],
  "version": "0.0.0",
  "homepage": "http://NightlyCommit.github.io/twing",
  "license": "BSD-2-Clause",
  "repository": {
    "type": "git",
    "url": "https://gitlab.com/nightlycommit/twing"
  },
  "main": "dist/cjs/index.js",
  "types": "dist/types/index.d.ts",
  "exports": {
    "import": "dist/es/index.js",
    "default": "dist/cjs/index.js",
    "types": "dist/types/index.d.ts"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=6.0.0"
  },
  "scripts": {
    "prebuild": "rimraf dist",
    "prebuild:test": "npm run prebuild",
    "prebuild:test:browser": "npm run prebuild:test",
    "precover": "rimraf coverage .nyc_output",
    "test": "node dist/test",
    "test:browser": "browserify dist/test/index.js | tape-run --sandbox=false",
    "cover": "c8 --src=dist/src --exclude-after-remap npm run test",
    "build": "npm run build:cjs && npm run build:es && npm run build:types",
    "build:cjs": "rimraf dist/cjs && tsc --project . --module commonjs --outDir dist/cjs",
    "build:es": "rimraf dist/es && tsc --project . --module es6 --outDir dist/es",
    "build:test": "rimraf dist && tsc --project test --outDir dist",
    "build:types": "rimraf dist/types && tsc --project . --declaration true --emitDeclarationOnly true --outDir dist/types",
    "bundle": "browserify dist/cjs/index.js -g uglifyify -s Twing -o dist/lib.min.js"
  },
  "dependencies": {
    "capitalize": "^1.0.0",
    "esrever": "^0.2.0",
    "htmlspecialchars": "^1.0.5",
    "iconv-lite": "^0.4.19",
    "is-plain-object": "^2.0.4",
    "isobject": "^3.0.1",
    "levenshtein": "^1.0.5",
    "locutus": "^2.0.11",
    "luxon": "^1.19.3",
    "pad": "^2.0.3",
    "regex-parser": "^2.2.8",
    "runes": "^0.4.3",
    "snake-case": "^2.1.0",
    "source-map": "^0.6.1",
    "twig-lexer": "^0.7.2",
    "utf8-binary-cutter": "^0.9.2"
  },
  "devDependencies": {
    "@types/locutus": "0.0.5",
    "@types/luxon": "^1.4.0",
    "@types/node": "^10.17.60",
    "@types/sinon": "^4.3.3",
    "@types/tape": "^4.2.33",
    "@types/tmp": "0.0.33",
    "browserify": "^16.2.3",
    "nyc": "^15.0.1",
    "rimraf": "^2.6.2",
    "sinon": "^6.3.4",
    "tape": "^5.6.1",
    "tape-run": "^11.0.0",
    "typescript": "^5.2.2",
    "uglifyify": "^5.0.1"
  }
}
