{
  "name": "@toppynl/twing",
  "version": "0.0.0-workspace-local",
  "private": true,
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "pnpm@10.30.0",
  "main": "src/main/target/index.cjs",
  "types": "src/main/target/lib.d.ts",
  "exports": {
    ".": {
      "import": "./src/main/target/index.cjs",
      "require": "./src/main/target/index.cjs",
      "types": "./src/main/target/lib.d.ts"
    },
    "./light": {
      "import": "./src/main/target/light/index.cjs",
      "require": "./src/main/target/light/index.cjs",
      "types": "./src/main/target/light/light.d.ts"
    }
  },
  "scripts": {
    "prebuild:test:browser": "npm run prebuild:test",
    "test": "node src/test/target/index.cjs && node src/test/target/entry.cjs",
    "test:browser": "browserify src/test/target/index.cjs | tape-run --sandbox=false",
    "build:lib": "(cd src/main && rollup -c) && cp README.md src/main/target/README.md && cp LICENSE src/main/target/LICENSE",
    "build:main": "npm run build:lib && npm run bundle",
    "build:test": "(cd src/test && rollup -c)",
    "bundle": "mkdir -p bundle && browserify src/main/target/index.cjs -g uglifyify -s Twing -o bundle/lib.min.js",
    "build:workspaces": "pnpm -r --filter=\"./packages/*\" build:main",
    "test:workspaces": "pnpm -r --filter=\"./packages/*\" test"
  },
  "dependencies": {
    "@nightlycommit/rollup-plugin-package-manifest": "^1.0.0-alpha.2",
    "@sinonjs/fake-timers": "11.2.2",
    "@types/capitalize": "^2.0.2",
    "@types/create-hash": "^1.2.5",
    "@types/esrever": "^0.2.3",
    "@types/levenshtein": "^1.0.4",
    "@types/locutus": "^0.0.8",
    "@types/luxon": "^1.4.0",
    "@types/node": "^16.18.126",
    "@types/runes": "^0.4.3",
    "@types/sinon": "^17.0.2",
    "@types/tape": "^5.8.1",
    "@vitrail/rollup-plugin-typescript": "^1.0.4-beta.0",
    "browserify": "^17.0.0",
    "capitalize": "^1.0.0",
    "common-shakeify": "^1.1.2",
    "esrever": "^0.2.0",
    "htmlspecialchars": "^1.0.5",
    "iconv-lite": "^0.6.3",
    "is-plain-object": "^2.0.4",
    "isobject": "^3.0.1",
    "levenshtein": "^1.0.5",
    "locutus": "^2.0.31",
    "luxon": "^1.19.3",
    "pad": "^2.0.3",
    "regex-parser": "^2.2.8",
    "runes": "^0.4.3",
    "sinon": "^17.0.1",
    "snake-case": "^2.1.0",
    "source-map": "^0.6.1",
    "tape": "^5.6.1",
    "tape-run": "^11.0.0",
    "twig-lexer": "^0.9.0",
    "uglifyify": "^5.0.2"
  },
  "devDependencies": {
    "rollup": "^4.0.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/exec": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.1",
    "@semantic-release/npm": "^12.0.1",
    "@semantic-release/release-notes-generator": "^14.0.3",
    "semantic-release": "^24.2.3",
    "semantic-release-monorepo": "^8.0.2"
  }
}
