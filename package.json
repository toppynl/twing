{
  "name": "twing",
  "description": "First-class Twig engine for Node.js",
  "author": "Eric MORAND <eric.morand@gmail.com>",
  "keywords": [
    "browser",
    "compiler",
    "template",
    "twig",
    "twig-engine",
    "typescript"
  ],
  "version": "0.0.0",
  "homepage": "https://twing-documentation-nightlycommit-4e8a287643e3fabd28bca6a83bd76.gitlab.io/",
  "license": "BSD-2-Clause",
  "repository": {
    "type": "git",
    "url": "https://gitlab.com/nightlycommit/twing"
  },
  "main": "dist/cjs/lib.js",
  "types": "dist/types/lib.d.ts",
  "jsdelivr": "dist/lib.min.js",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=6.0.0"
  },
  "scripts": {
    "prebuild": "rimraf dist",
    "prebuild:test": "npm run prebuild",
    "prebuild:test:browser": "npm run prebuild:test",
    "test": "node dist/test",
    "test:browser": "browserify dist/test/index.js | tape-run --sandbox=false",
    "build": "npm run build:cjs && npm run build:types && npm run bundle",
    "build:cjs": "rimraf dist/cjs && tsc --project . --module commonjs --outDir dist/cjs",
    "build:test": "rimraf dist && tsc --project test --outDir dist",
    "build:types": "rimraf dist/types && tsc --project . --declaration true --emitDeclarationOnly true --outDir dist/types",
    "bundle": "browserify dist/cjs/lib.js -g uglifyify -s Twing -o dist/lib.min.js"
  },
  "dependencies": {
    "capitalize": "^1.0.0",
    "create-hash": "^1.2.0",
    "esrever": "^0.2.0",
    "htmlspecialchars": "^1.0.5",
    "iconv-lite": "^0.4.19",
    "is-plain-object": "^2.0.4",
    "isobject": "^3.0.1",
    "levenshtein": "^1.0.5",
    "locutus": "^2.0.11",
    "luxon": "^1.19.3",
    "pad": "^2.0.3",
    "regex-parser": "^2.2.8",
    "runes": "^0.4.3",
    "snake-case": "^2.1.0",
    "source-map": "^0.6.1",
    "twig-lexer": "^0.9.0",
    "utf8-binary-cutter": "^0.9.2"
  },
  "devDependencies": {
    "@types/create-hash": "^1.2.5",
    "@types/locutus": "^0.0.8",
    "@types/luxon": "^1.4.0",
    "@types/node": "^10.17.60",
    "@types/sinon": "^17.0.2",
    "@types/tape": "^4.2.33",
    "browserify": "^17.0.0",
    "common-shakeify": "^1.1.2",
    "rimraf": "^2.6.2",
    "sinon": "^17.0.1",
    "tape": "^5.6.1",
    "tape-run": "^11.0.0",
    "typescript": "^5.2.2",
    "uglifyify": "^5.0.1"
  }
}
