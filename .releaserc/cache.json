{
  "extends": "semantic-release-monorepo",
  "tagFormat": "twing-cache-extra-v${version}",
  "branches": ["main"],
  "plugins": [
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    [
      "@semantic-release/changelog",
      {
        "changelogFile": "CHANGELOG.md"
      }
    ],
    [
      "@semantic-release/npm",
      {
        "npmPublish": false,
        "pkgRoot": "."
      }
    ],
    [
      "@semantic-release/exec",
      {
        "publishCmd": "NEXT_VERSION=${nextRelease.version} bash ../../scripts/publish-workspaces.sh @toppynl/twing-cache-extra packages/cache"
      }
    ],
    [
      "@semantic-release/git",
      {
        "assets": [
          "package.json",
          "CHANGELOG.md"
        ],
        "message": "chore(release): @toppynl/twing-cache-extra@${nextRelease.version} [skip ci]"
      }
    ],
    ["@semantic-release/github", {"successComment": false, "failComment": false}]
  ]
}
